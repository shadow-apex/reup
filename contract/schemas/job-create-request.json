{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reup-video.local/schemas/job-create-request.json",
  "type": "object",
  "required": ["contract_version", "job_id", "input_video_path", "output_dir"],
  "properties": {
    "contract_version": { "type": "string", "const": "1" },
    "job_id": { "type": "string", "format": "uuid" },
    "input_video_path": { "type": "string", "minLength": 1 },
    "output_dir": { "type": "string", "minLength": 1 },
    "source_language": { "type": "string", "default": "zh" },
    "target_language": { "type": "string", "default": "vi" },

    "openai_base_url": { "type": "string", "default": "https://api.deepseek.com" },
    "openai_api_key": { "type": "string", "default": "" },
    "openai_model": { "type": "string", "default": "deepseek-chat" },

    "vol_orig": { "type": "number", "default": 15, "minimum": 0, "maximum": 100 }
  },
  "additionalProperties": false
}
