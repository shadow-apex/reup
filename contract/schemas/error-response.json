{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reup-video.local/schemas/error-response.json",
  "type": "object",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "detail": { "type": ["string", "null"] },
        "ffmpeg_exit_code": { "type": ["integer", "null"] }
      }
    }
  },
  "additionalProperties": false
}
