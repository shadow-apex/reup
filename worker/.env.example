# Shared with Laravel VIDEO_WORKER_SECRET
WORKER_SECRET=change-me-in-dev

# ffmpeg on PATH or full path
FFMPEG_PATH=ffmpeg
FFMPEG_TIMEOUT_SECONDS=3600

# stub = no ASR/API; real = faster-whisper + OpenAI-compatible translate + edge-tts
PIPELINE_MODE=stub

# OpenAI-compatible translation (required for PIPELINE_MODE=real unless you only use stub)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Whisper (PIPELINE_MODE=real)
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# edge-tts voice for Vietnamese
EDGE_TTS_VOICE=vi-VN-HoaiMyNeural
