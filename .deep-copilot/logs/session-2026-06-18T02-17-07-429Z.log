[2026-06-18T02:28:31.928Z] [TOOL_CALL] {"id":"call_00_u96r4MotOPn735G1TvxC8617","name":"write_file","args":{"content":"import tkinter as tk\nfrom tkinter import ttk, filedialog, messagebox, scrolledtext\nimport threading\nimport os\nimport json\nimport re\nimport uuid\nimport time\nimport subprocess\nimport urllib.request\nimport urllib.error\nimport ssl\n\n# ─── CONFIG ─────────────────────────────────────────────────────────────────\nCONFIG_FILE = \"reup_config.json\"\n\ndef load_config():\n    if os.path.exists(CONFIG_FILE):\n        with open(CONFIG_FILE, \"r\", encoding=\"utf-8\") as f:\n            return json.load(f)\n    return {}\n\ndef save_config(cfg):\n    with open(CONFIG_FILE, \"w\", encoding=\"utf-8\") as f:\n        json.dump(cfg, f, indent=2, ensure_ascii=False)\n\n# ─── COLORS ─────────────────────────────────────────────────────────────────\nBG, PANEL, CARD = \"#0f0f13\", \"#1a1a22\", \"#22222e\"\nACCENT, ACCENT2 = \"#7c5cfc\", \"#a78bfa\"\nGREEN, RED, YELLOW = \"#22c55e\", \"#ef4444\", \"#f59e0b\"\nTEXT, SUBTEXT, BORDER = \"#e2e8f0\", \"#94a3b8\", \"#2e2e3e\"\nFONT_SM = (\"Segoe UI\", 8)\nFONT_BASE = (\"Segoe UI\", 9)\nFONT_MED = (\"Segoe UI\", 10, \"bold\")\nFONT_LG = (\"Segoe UI\", 12, \"bold\")\nFONT_XL  = (\"Segoe UI\", 14, \"bold\")\n\nLANGS = [\"zh\", \"vi\", \"en\", \"ja\", \"ko\", \"fr\", \"de\", \"th\", \"id\", \"ms\"]\nLANG_NAMES = {\"zh\":\"Trung\",\"vi\":\"Việt\",\"en\":\"Anh\",\"ja\":\"Nhật\",\"ko\":\"Hàn\",\n              \"fr\":\"Pháp\",\"de\":\"Đức\",\"th\":\"Thái\",\"id\":\"Indo\",\"ms\":\"Mã Lai\"}\n\n# ─── TOOLTIP ────────────────────────────────────────────────────────────────\nclass ToolTip:\n    def __init__(self, widget, text):\n        self.widget = widget\n        self.text = text\n        widget.bind(\"<Enter>\", self.show)\n        widget.bind(\"<Leave>\", self.hide)\n        self.tw = None\n    def show(self, event=None):\n        x = self.widget.winfo_rootx()+20; y = self.widget.winfo_rooty()+self.widget.winfo_height()+4\n        self.tw = tw = tk.Toplevel(self.widget); tw.wm_overrideredirect(True); tw.wm_geometry(f\"+{x}+{y}\")\n        tk.Label(tw, text=self.text, bg=\"#2d2d3f\", fg=TEXT, font=FONT_SM, padx=6, pady=3).pack()\n    def hide(self, event=None):\n        if self.tw: self.tw.destroy(); self.tw = None\n\n# ─── HELPERS ────────────────────────────────────────────────────────────────\ndef styled_btn(parent, text, cmd, color=ACCENT, width=None, small=False):\n    f = FONT_SM if small else FONT_BASE; w = width or (8 if small else 10)\n    return tk.Button(parent, text=text, command=cmd, bg=color, fg=\"#fff\", font=f,\n                     relief=\"flat\", bd=0, padx=6, pady=3 if small else 5,\n                     cursor=\"hand2\", activebackground=ACCENT2, activeforeground=\"#fff\", width=w)\n\ndef _json_http(url, method=\"GET\", headers=None, data=None, timeout=30):\n    ctx = ssl.create_default_context(); ctx.check_hostname = False; ctx.verify_mode = ssl.CERT_NONE\n    req = urllib.request.Request(url, method=method)\n    if headers:\n        for k,v in headers.items(): req.add_header(k,v)\n    if data is not None:\n        req.data = json.dumps(data).encode(\"utf-8\"); req.add_header(\"Content-Type\",\"application/json; charset=utf-8\")\n    try:\n        with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:\n            return r.status, json.loads(r.read().decode(\"utf-8\")), None\n    except urllib.error.HTTPError as e:\n        try: return e.code, json.loads(e.read().decode(\"utf-8\")), None\n        except: return e.code, None, f\"HTTP {e.code}\"\n    except urllib.error.URLError as e: return 0, None, f\"Không thể kết nối: {e.reason}\"\n    except Exception as e: return 0, None, str(e)\n\nclass ReupApp(tk.Tk):\n    def __init__(self):\n        super().__init__()\n        self.title(\"🎬 Video Reup Tool\"); self.configure(bg=BG); self.resizable(False,False)\n        cfg = load_config()\n        self.openai_key   = tk.StringVar(value=cfg.get(\"openai_key\",\"\"))\n        self.worker_url   = tk.StringVar(value=cfg.get(\"worker_url\",\"http://127.0.0.1:8765\"))\n        self.worker_secret= tk.StringVar(value=cfg.get(\"worker_secret\",\"change-me-in-dev\"))\n        self.src_lang     = tk.StringVar(value=cfg.get(\"src_lang\",\"zh\"))\n        self.tgt_lang     = tk.StringVar(value=cfg.get(\"tgt_lang\",\"vi\"))\n   …(+19193 chars)","path":"c:\\Users\\Hanh\\Downloads\\reup-video\\gui.py"}}
